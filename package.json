{
  "name": "status-dashboard",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "npm install --prefix client && npm run build --prefix client && cp -r client/dist server/public && npm install --prefix server && npm run build --prefix server",
    "start": "node server/dist/index.js",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
